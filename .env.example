# Server
PORT=10000
PUBLIC_BASE_URL=https://getstorescout.com
DEV_SKIP_PAYMENT=false

# Stripe (legacy one-time + new subscriptions)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...           # legacy $9 one-time
STRIPE_PRO_PRICE_ID=price_...       # $29/month Pro
STRIPE_AGENCY_PRICE_ID=price_...    # $79/month Agency

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM=StoreScout <hello@getstorescout.com>

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Tier configuration
FREE_SCAN_INTERVAL_HOURS=168
PRO_SCAN_INTERVAL_HOURS=24
AGENCY_SCAN_INTERVAL_HOURS=12
FREE_MAX_COMPETITORS=1
PRO_MAX_COMPETITORS=10
AGENCY_MAX_COMPETITORS=50
